---
import ResonanceColumn from '@components/ResonanceColumn.astro';
import logo from '../images/logo.webp';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Alma Dendera — Soundhealing</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz@9..144&family=IBM+Plex+Mono&family=Public+Sans&display=swap" rel="stylesheet" />
  </head>
  <body>
    <ResonanceColumn />
    <main>
      <section id="hero">
        <div class="hero-bg"></div>
        <div class="hero-content">
          <img src={logo.src} alt="Alma Dendera" class="hero-logo" width={logo.width} height={logo.height} />
          <h1 class="hero-title">Alma Dendera</h1>
          <p class="hero-tagline">Sonido que encuentra el camino de vuelta</p>
          <div class="hero-waves" aria-hidden="true">
            <span class="wave-ring"></span>
            <span class="wave-ring"></span>
            <span class="wave-ring"></span>
          </div>
        </div>
        <div class="scroll-indicator" aria-hidden="true">
          <span class="scroll-line"></span>
          <span class="scroll-text">descubre</span>
        </div>
      </section>
      <section id="comprension"></section>
      <section id="servicios"></section>
      <section id="contacto"></section>
    </main>
  </body>
</html>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        } else {
          entry.target.classList.remove('visible');
        }
      });
    },
    { threshold: 0.1 }
  );

  const indicator = document.querySelector('.scroll-indicator');
  if (indicator) observer.observe(indicator);

  const tagline = document.querySelector('.hero-tagline');
  if (tagline) {
    setTimeout(() => tagline.classList.add('visible'), 600);
  }
</script>

<style>
  :global(*) { margin: 0; padding: 0; box-sizing: border-box; }
  :global(body) { background: #12100E; }
  :global(section) { height: 100vh; min-height: 100vh; }

  #hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #12100E;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 40%, rgba(201, 155, 74, 0.06) 0%, transparent 60%);
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
    animation: hero-float 1.8s ease-out;
  }

  @keyframes hero-float {
    0% { opacity: 0; transform: translateY(12px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .hero-logo {
    width: 72px;
    height: auto;
    opacity: 0.85;
    margin-bottom: 0.25rem;
  }

  .hero-title {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    color: #C99B4A;
    letter-spacing: 0.04em;
    line-height: 1.1;
  }

  .hero-tagline {
    font-family: 'Public Sans', sans-serif;
    font-size: clamp(0.95rem, 1.8vw, 1.15rem);
    color: #B9C4C2;
    max-width: 30ch;
    line-height: 1.6;
    font-weight: 300;
    opacity: 0;
    transition: opacity 1.2s ease;
  }

  .hero-tagline.visible {
    opacity: 1;
  }

  .hero-waves {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .wave-ring {
    position: absolute;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    border: 1px solid rgba(201, 155, 74, 0.08);
    animation: breathe 8s ease-in-out infinite;
  }

  .wave-ring:nth-child(2) {
    width: 300px;
    height: 300px;
    animation-delay: -2.7s;
  }

  .wave-ring:nth-child(3) {
    width: 440px;
    height: 440px;
    animation-delay: -5.3s;
  }

  @keyframes breathe {
    0%, 100% { transform: scale(0.85); opacity: 0.08; }
    50% { transform: scale(1.08); opacity: 0.18; }
  }

  .scroll-indicator {
    position: absolute;
    bottom: 3rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 1;
    opacity: 1;
    transition: opacity 0.8s ease;
  }

  .scroll-indicator:not(.visible) {
    opacity: 0;
  }

  .scroll-line {
    display: block;
    width: 1px;
    height: 32px;
    background: linear-gradient(to bottom, #C99B4A, transparent);
    animation: scroll-pulse 2s ease-in-out infinite;
  }

  .scroll-text {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #6B4550;
  }

  @keyframes scroll-pulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.3); }
  }

  :global(#comprension) { background: #F7F3EC; }
  :global(#servicios) { background: #12100E; }
  :global(#contacto) { background: #12100E; }

  @media (prefers-reduced-motion: reduce) {
    :global(.hero-title), :global(.hero-tagline) { animation: none; opacity: 1; }
    :global(.wave-ring) { animation: none; opacity: 0.08; }
    :global(.scroll-line) { animation: none; opacity: 0.5; }
  }
</style>
