---
const sections = [
  { id: 'hero', label: 'Hero' },
  { id: 'comprension', label: 'Comprensión' },
  { id: 'servicios', label: 'Servicios' },
  { id: 'contacto', label: 'Contacto' },
];
---

<div id="resonance-column" class="resonance-column">
  <div class="resonance-line" aria-hidden="true"></div>
  <nav aria-label="Navegación del camino">
    {sections.map((section, i) => (
      <button
        class="waypoint"
        data-section={section.id}
        data-index={i}
        aria-label={`Ir a ${section.label}`}
      >
        <span class="waypoint-dot"></span>
        <span class="waypoint-label">{section.label}</span>
      </button>
    ))}
  </nav>
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const column = document.getElementById('resonance-column');
  const line = column.querySelector('.resonance-line');
  const waypoints = column.querySelectorAll('.waypoint');

  waypoints.forEach((wp) => {
    wp.addEventListener('click', () => {
      const section = document.getElementById(wp.dataset.section);
      if (section) section.scrollIntoView({ behavior: 'smooth' });
    });
  });

  const mm = gsap.matchMedia();

  mm.add('(min-width: 769px)', () => {
    gsap.to(line, {
      scaleY: 1,
      transformOrigin: 'top center',
      scrollTrigger: {
        trigger: document.body,
        start: 'top top',
        end: 'bottom bottom',
        scrub: 1,
      },
    });
  });

  mm.add('(max-width: 768px)', () => {
    gsap.to(line, {
      width: '100%',
      transformOrigin: 'left center',
      scrollTrigger: {
        trigger: document.body,
        start: 'top top',
        end: 'bottom bottom',
        scrub: 1,
      },
    });
  });

  for (const wp of waypoints) {
    const section = document.getElementById(wp.dataset.section);
    if (!section) continue;

    ScrollTrigger.create({
      trigger: section,
      start: 'top center',
      end: 'bottom center',
      onEnter: () => {
        waypoints.forEach((w) => w.classList.remove('active'));
        wp.classList.add('active');
      },
      onEnterBack: () => {
        waypoints.forEach((w) => w.classList.remove('active'));
        wp.classList.add('active');
      },
    });
  }
</script>

<style>
  .resonance-column {
    position: fixed;
    top: 0;
    right: 2rem;
    height: 100vh;
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .resonance-line {
    position: absolute;
    top: 10vh;
    bottom: 10vh;
    width: 2px;
    background: #C99B4A;
    transform: scaleY(0);
    transform-origin: top center;
  }

  nav {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
    padding: 10vh 0;
  }

  .waypoint {
    all: unset;
    position: relative;
    display: flex;
    align-items: center;
    cursor: pointer;
    pointer-events: auto;
  }

  .waypoint-dot {
    display: block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #6B4550;
    border: 2px solid transparent;
    transition: background 0.4s ease, border-color 0.4s ease, transform 0.3s ease;
    position: relative;
    z-index: 1;
  }

  .waypoint:hover .waypoint-dot {
    transform: scale(1.35);
  }

  .waypoint.active .waypoint-dot {
    background: #C99B4A;
    border-color: #C99B4A;
    box-shadow: 0 0 8px rgba(201, 155, 74, 0.5);
  }

  .waypoint-label {
    position: absolute;
    right: calc(100% + 16px);
    white-space: nowrap;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #B9C4C2;
    opacity: 0;
    transform: translateX(6px);
    transition: opacity 0.25s ease, transform 0.25s ease;
    pointer-events: none;
  }

  .waypoint:hover .waypoint-label,
  .waypoint.active .waypoint-label {
    opacity: 1;
    transform: translateX(0);
  }

  @media (max-width: 768px) {
    .resonance-column {
      top: 0;
      right: 0;
      left: 0;
      height: auto;
      flex-direction: row;
      padding: 0;
      justify-content: center;
    }

    .resonance-line {
      top: auto;
      bottom: auto;
      height: 3px;
      width: 0%;
      transform: none;
    }

    nav {
      flex-direction: row;
      gap: 0;
      padding: 0;
      width: 100%;
      justify-content: space-around;
      position: absolute;
      top: -8px;
    }

    .waypoint-dot {
      width: 14px;
      height: 14px;
    }

    .waypoint-label {
      display: none;
    }
  }
</style>
