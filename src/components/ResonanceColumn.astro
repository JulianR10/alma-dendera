---
const sections = [
  { id: 'hero', label: 'Hero' },
  { id: 'comprension', label: 'Comprensión' },
  { id: 'servicios', label: 'Servicios' },
  { id: 'contacto', label: 'Contacto' },
];
---

<div id="resonance-column" class="resonance-column">
  <svg class="resonance-line" viewBox="0 0 30 1000" preserveAspectRatio="none" aria-hidden="true">
    <path d="M 15,0
             C 17,33 17,67 15,100
             C 11,133 11,167 8,200
             C 22,233 22,267 15,300
             C 5,333 5,367 8,400
             C 27,433 27,467 15,500
             C 3,533 3,567 8,600
             C 25,633 25,667 15,700
             C 8,733 8,767 8,800
             C 19,833 19,867 15,900
             C 13,933 13,967 15,1000"
          fill="none"
          stroke="#C99B4A"
          stroke-width="2"
          stroke-linecap="round" />
  </svg>
  <div class="resonance-line-mobile" aria-hidden="true"></div>
  <nav aria-label="Navegación del camino">
    {sections.map((section, i) => (
      <button
        class="waypoint"
        data-section={section.id}
        data-index={i}
        aria-label={`Ir a ${section.label}`}
      >
        <span class="waypoint-dot"></span>
        <span class="waypoint-label">{section.label}</span>
      </button>
    ))}
  </nav>
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const column = document.getElementById('resonance-column');
  const path = column.querySelector('.resonance-line path');
  const mobileLine = column.querySelector('.resonance-line-mobile');
  const waypoints = column.querySelectorAll('.waypoint');

  const length = path.getTotalLength();
  path.style.strokeDasharray = length;
  path.style.strokeDashoffset = length;

  waypoints.forEach((wp) => {
    wp.addEventListener('click', () => {
      const section = document.getElementById(wp.dataset.section);
      if (section) section.scrollIntoView({ behavior: 'smooth' });
    });
  });

  // Waypoints posicionados informalmente sobre la onda

  const mm = gsap.matchMedia();

  mm.add('(min-width: 769px)', () => {
    gsap.fromTo(path,
      { strokeDashoffset: length },
      {
        strokeDashoffset: 0,
        ease: 'none',
        scrollTrigger: {
          trigger: document.body,
          start: 'top top',
          end: 'bottom bottom',
          scrub: 1,
        },
      }
    );
  });

  mm.add('(max-width: 768px)', () => {
    gsap.fromTo(mobileLine,
      { width: '0%' },
      {
        width: '100%',
        ease: 'none',
        scrollTrigger: {
          trigger: document.body,
          start: 'top top',
          end: 'bottom bottom',
          scrub: 1,
        },
      }
    );
  });

  for (const wp of waypoints) {
    const section = document.getElementById(wp.dataset.section);
    if (!section) continue;

    ScrollTrigger.create({
      trigger: section,
      start: 'top center',
      end: 'bottom center',
      onEnter: () => {
        waypoints.forEach((w) => w.classList.remove('active'));
        wp.classList.add('active');
      },
      onEnterBack: () => {
        waypoints.forEach((w) => w.classList.remove('active'));
        wp.classList.add('active');
      },
    });
  }
</script>

<style>
  .resonance-column {
    position: fixed;
    top: 0;
    right: 1.5rem;
    width: 30px;
    height: 100vh;
    z-index: 100;
  }

  .resonance-line {
    position: absolute;
    top: 10vh;
    bottom: 10vh;
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .resonance-line-mobile {
    display: none;
  }

  nav {
    position: absolute;
    top: 10vh;
    bottom: 10vh;
    left: 0;
    right: 0;
  }

  .waypoint {
    all: unset;
    position: absolute;
    left: 50%;
    transform: translate(-50%, -50%);
    cursor: pointer;
    pointer-events: auto;
  }

  .waypoint[data-index="0"] { top: 20%; }
  .waypoint[data-index="1"] { top: 40%; }
  .waypoint[data-index="2"] { top: 60%; }
  .waypoint[data-index="3"] { top: 80%; }

  .waypoint-dot {
    display: block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #6B4550;
    border: 2px solid transparent;
    transition: background 0.4s ease, border-color 0.4s ease, transform 0.3s ease;
    position: relative;
    z-index: 1;
  }

  .waypoint:hover .waypoint-dot {
    transform: scale(1.35);
  }

  .waypoint.active .waypoint-dot {
    background: #C99B4A;
    border-color: #C99B4A;
    box-shadow: 0 0 8px rgba(201, 155, 74, 0.5);
  }

  .waypoint-label {
    position: absolute;
    right: calc(100% + 16px);
    top: 50%;
    transform: translateY(-50%);
    white-space: nowrap;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #B9C4C2;
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }

  .waypoint:hover .waypoint-label,
  .waypoint.active .waypoint-label {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .resonance-column {
      top: 0;
      right: 0;
      left: 0;
      width: 100%;
      height: auto;
    }

    .resonance-line {
      display: none;
    }

    .resonance-line-mobile {
      display: block;
      position: absolute;
      top: 0;
      left: 0;
      height: 3px;
      width: 0%;
      background: #C99B4A;
    }

    nav {
      position: absolute;
      top: 0;
      bottom: auto;
      left: 0;
      right: 0;
      display: flex;
      flex-direction: row;
      justify-content: space-around;
      padding: 0;
      height: 14px;
    }

    .waypoint {
      position: static;
      transform: none;
    }

    .waypoint-dot {
      width: 14px;
      height: 14px;
    }

    .waypoint-label {
      display: none;
    }
  }
</style>
