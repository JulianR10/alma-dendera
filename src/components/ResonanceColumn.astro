---
// Columna de resonancia — Desktop: vertical | Mobile: barra horizontal superior
// Animaciones aisladas con GSAP, scoped a este componente
---
<div id="resonance-column" class="resonance-column">
  <div class="resonance-line" aria-hidden="true"></div>
  <div class="waypoint" data-point="1"></div>
  <div class="waypoint" data-point="2"></div>
  <div class="waypoint" data-point="3"></div>
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Animaciones scoped — solo afectan a #resonance-column
  gsap.to('#resonance-column .resonance-line', {
    scaleY: 1,
    transformOrigin: 'top center',
    scrollTrigger: {
      trigger: document.body,
      start: 'top top',
      end: 'bottom bottom',
      scrub: 1,
    },
  });
</script>

<style>
  .resonance-column {
    position: fixed;
    top: 0;
    right: 2rem;
    height: 100vh;
    width: 2px;
    z-index: 100;
    pointer-events: none;
  }

  .resonance-line {
    width: 100%;
    height: 100%;
    background: #C99B4A;
    transform: scaleY(0);
  }

  .waypoint {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #6B4550;
    transition: background 0.4s ease;
  }

  .waypoint[data-point="1"] { top: 25%; }
  .waypoint[data-point="2"] { top: 50%; }
  .waypoint[data-point="3"] { top: 75%; }

  @media (max-width: 768px) {
    .resonance-column {
      top: 0;
      right: 0;
      left: 0;
      height: 3px;
      width: 100%;
    }

    .resonance-line {
      height: 100%;
      width: 0%;
      transform: none;
    }

    .waypoint {
      top: -2.5px !important;
      left: auto;
    }

    .waypoint[data-point="1"] { left: 25%; }
    .waypoint[data-point="2"] { left: 50%; }
    .waypoint[data-point="3"] { left: 75%; }
  }
</style>
